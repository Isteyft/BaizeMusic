{
  "name": "@baize/mobile",
  "version": "1.0.0",
  "private": true,
  "main": "index.js",
  "description": "Baize React Native mobile app",
  "scripts": {
    "dev": "expo start --clear",
    "android": "expo run:android --device",
    "emulator": "powershell -ExecutionPolicy Bypass -File ./scripts/start-emulator.ps1",
    "android:release": "powershell -ExecutionPolicy Bypass -File ./scripts/build-release.ps1",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "web:offline": "expo start --web --offline",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "author": "Isteyft",
  "license": "ISC",
  "dependencies": {
    "@baize/types": "workspace:*",
    "@baize/utils": "workspace:*",
    "@expo/metro-runtime": "~4.0.1",
    "expo": "~52.0.46",
    "expo-av": "~15.0.2",
    "expo-document-picker": "~13.0.3",
    "expo-file-system": "~18.0.12",
    "expo-status-bar": "~2.0.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.9",
    "react-native-web": "~0.19.13"
  },
  "devDependencies": {
    "@types/react": "^18.3.19",
    "typescript": "^5.6.3"
  }
}
